
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // =========================================================
    // 1. 基礎權限判斷函數
    // =========================================================
    
    // 判斷是否為登入用戶
    function isAuth() {
      return request.auth != null;
    }

    // 判斷是否為資料擁有者
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // 判斷是否為管理員 (讀取 user document 的 role 欄位)
    // 注意：這會多消耗一次讀取配額
    function isAdmin() {
      return isAuth() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // =========================================================
    // 2. 集合規則 (Collections)
    // =========================================================

    // 用戶資料 (Users)
    // - 擁有者可讀寫自己
    // - 管理員可讀寫所有人 (解決後台讀取問題)
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      // 用戶底下的貼文 (Posts)
      match /posts/{postId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // 品牌設定 (Brand Settings)
    match /brand_settings/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // 接案名片 (Public Profiles)
    // - 所有人可讀取 (為了人才星探功能)
    // - 只有擁有者或管理員可修改
    match /connect_profiles/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    // 發案活動 (Campaigns)
    match /campaigns/{campaignId} {
      allow read: if true;
      allow create: if isAuth(); // 允許登入者發案
      allow update, delete: if isAuth() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // 報名紀錄 (Campaign Applications)
    match /campaign_applications/{appId} {
      allow create: if isAuth();
      // 只有發起該申請的人或管理員可以讀取 (實作上可能需要更細的規則讓廠商讀取，此處簡化)
      allow read: if isAuth() || isAdmin(); 
    }
    
    // 解鎖紀錄 (Connect Unlocks)
    match /connect_unlocks/{unlockId} {
        allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
        allow create: if isAuth();
    }

    // 管理員金鑰 (Admin Keys)
    // - 嚴格限制只有管理員能讀寫
    match /admin_keys/{keyId} {
      allow read, write: if isAdmin(); 
    }

    // 使用紀錄 (Usage Logs)
    match /usage_logs/{logId} {
      allow create: if isAuth();
      allow read, delete: if isAdmin();
    }

    // 用戶回報 (User Reports)
    match /user_reports/{reportId} {
      allow create: if true;
      allow read, update: if isAdmin();
    }

    // 系統統計 (System Stats)
    match /system_stats/{docId} {
      allow read, write: if isAdmin();
    }
    
    // 配額交易紀錄 (Quota Transactions)
    match /quota_transactions/{txId} {
       allow read: if isOwner(resource.data.userId) || isAdmin();
       allow create: if isAuth(); // 前端扣點模式需允許寫入
    }
    
    // API Queue
    match /api_queue/{ticketId} {
       allow read, write: if isAuth();
    }
  }
}
