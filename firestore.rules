
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // =========================================================
    // 1. 基礎權限判斷函數 (Helpers)
    // =========================================================
    
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // 判斷是否為管理員
    // 透過讀取 users 集合中該用戶的 role 欄位是否為 'admin'
    function isAdmin() {
      return isAuth() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // =========================================================
    // 2. 集合規則 (Collection Rules)
    // =========================================================

    // 用戶資料 (Users)
    // 允許管理員讀取所有文件 (列表)，用戶只能讀寫自己的
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      match /posts/{postId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // 品牌設定
    match /brand_settings/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // 接案名片 (公開)
    match /connect_profiles/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    // 合作案件
    match /campaigns/{campaignId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAuth() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // 案件報名
    match /campaign_applications/{appId} {
      allow create: if isAuth();
      allow read: if isAuth() || isAdmin();
    }
    
    // 解鎖聯絡資訊紀錄
    match /connect_unlocks/{unlockId} {
        allow create: if isAuth();
        allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // 管理員金鑰 (嚴格限制)
    match /admin_keys/{keyId} {
      allow read, write: if isAdmin(); 
    }

    // 操作日誌 (Admin Dashboard 用)
    match /usage_logs/{logId} {
      allow create: if isAuth();
      allow read, delete: if isAdmin();
    }

    // 用戶回報
    match /user_reports/{reportId} {
      allow create: if true;
      allow read, update: if isAdmin();
    }

    // 系統統計
    match /system_stats/{docId} {
      allow read, write: if isAdmin();
    }
    
    // 系統快取 (Gemini 搜尋結果快取)
    match /system_cache/{key} {
       allow read, write: if isAuth();
    }
    
    // 社群股市資料 (Shared Cache for Trending Stocks)
    // 允許所有登入用戶讀取與寫入 (前端觸發更新機制)
    match /trending_stocks/{stockId} {
       allow read, write: if isAuth();
    }
    
    // 配額交易紀錄
    match /quota_transactions/{txId} {
       allow create: if isAuth();
       allow read: if isOwner(resource.data.userId) || isAdmin();
    }
    
    // API 排隊系統
    match /api_queue/{ticketId} {
       allow read, write: if isAuth();
    }
  }
}
